{
	"compilerOptions": {
		"module": "esnext",
		"moduleResolution": "Bundler",
		"isolatedModules": true,
		"useDefineForClassFields": true,
		"verbatimModuleSyntax": true,
		"target": "ES2022",
		"sourceMap": true,
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
		"composite": true,
		"strictNullChecks": true,
	},
	"compileOnSave": true,
	"references": [
		{
			"path": "src/"
		},
		{
			"path": "packages/boreas/"
		},
	],
}
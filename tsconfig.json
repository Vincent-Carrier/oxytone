{
	"compilerOptions": {
		"paths": {
			"@/*": [
				"./src/*"
			],
			"npm:*": [
				"./node_modules/*"
			]
		},
		"module": "esnext",
		"moduleResolution": "Bundler",
		"isolatedModules": true,
		"useDefineForClassFields": true,
		"verbatimModuleSyntax": true,
		"target": "ES2022",
		"sourceMap": true,
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
	},
	"compileOnSave": true,
	"files": [
		"src/reader.ts"
	]
}